    "dev": "node -e \"const{spawn}=require('child_process');const s=spawn('npx',['tsx','server/index.ts'],{stdio:'inherit'});const v=spawn('npx',['vite'],{stdio:'inherit'});process.on('SIGTERM',()=>{s.kill();v.kill();process.exit(0)})\"",
