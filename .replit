modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
MARKET_PROVIDER_PRIMARY = "finnhub"
MARKET_PROVIDER_SECONDARY = "yahoo_finance"
NEWS_PROVIDER_PRIMARY = "finnhub"
NEWS_PROVIDER_SECONDARY = "yahoo_finance"
MACRO_PROVIDER_PRIMARY = "fred"
FX_PROVIDER_PRIMARY = "frankfurter"
FX_PROVIDER_SECONDARY = "cbuae"
FILING_PROVIDER_PRIMARY = "sec_edgar"
IDENTITY_PROVIDER_PRIMARY = "openfigi"
VITE_DEMO_MODE = "false"
VITE_POSTHOG_HOST = "https://us.i.posthog.com"
VITE_GA4_MEASUREMENT_ID = "G-V823WN3NG9"
